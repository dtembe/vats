# VATS - Versatile Audio Transcription & Summarization
# Copy this file to .env and update values as needed

# ---------------------------------------------------------------
# AI Model Selection (ollama, gemini, deepseek, openrouter, zai)
# ---------------------------------------------------------------
AI_MODEL=ollama

# Ollama Configuration (local LLM, no API key required)
OLLAMA_API_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3

# Google Gemini
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-pro

# DeepSeek
# DEEPSEEK_API_KEY=your_deepseek_api_key_here
# DEEPSEEK_API_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-chat

# OpenRouter (access to Claude, GPT-4, etc.)
# OPENROUTER_API_KEY=your_openrouter_api_key_here
# OPENROUTER_API_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=anthropic/claude-3-haiku

# Z.ai
# ZAI_API_KEY=your_zai_api_key_here
# ZAI_API_URL=https://api.z.ai/api/coding/paas/v4
# ZAI_MODEL=glm-4.6
# ZAI_TIMEOUT=300

# Max tokens for summary generation (applies to all providers)
# Increase for large transcripts or detailed summaries
SUMMARY_MAX_TOKENS=32768

# ---------------------------------------------------------------
# Hugging Face (required for speaker diarization)
# ---------------------------------------------------------------
# HF_AUTH_TOKEN=your_huggingface_token_here

# ---------------------------------------------------------------
# Whisper Configuration
# ---------------------------------------------------------------
WHISPER_MODEL=small
WHISPER_LANGUAGE=en

# Whisper.cpp — enable for maximum local/CPU performance
# USE_WHISPER_CPP=true
# WHISPER_CPP_PATH=C:/tools/whisper.cpp/build/bin/Release/whisper-cli.exe

# ---------------------------------------------------------------
# VAD / Transcription Tuning
# ---------------------------------------------------------------
VAD_THRESHOLD=0.5
BEAM_SIZE=1
MIN_SEGMENT_LENGTH=1.0
MAX_SEGMENT_LENGTH=30.0
SILENCE_PADDING=0.5

# ---------------------------------------------------------------
# Diarization
# ---------------------------------------------------------------
ENABLE_DIARIZATION=true
MAX_SPEAKERS=10

# ---------------------------------------------------------------
# Processing
# ---------------------------------------------------------------
AUDIO_SEGMENT_LENGTH=120
NUM_THREADS=8
DEFAULT_TEMP_DIR=

# ---------------------------------------------------------------
# Summarization
# ---------------------------------------------------------------
ENABLE_SUMMARIZATION=true
SUMMARY_PROMPT_FILE=prompts/vats_summary_prompt_extract_wisdom.txt
# AV_SUMMARY_PROMPT_FILE=prompts/vats_summary_extract_wisdom.txt
# TEXT_SUMMARY_PROMPT_FILE=prompts/vats_summarize_meeting_fabric.txt

# ---------------------------------------------------------------
# Performance
# ---------------------------------------------------------------
PERFORMANCE_PROFILE=speed
ENABLE_PARALLEL_PROCESSING=true
MAX_TRANSCRIPTION_WORKERS=3
ENABLE_AUDIO_PARALLEL_SPLITTING=true
MAX_AUDIO_SPLITTING_WORKERS=6
USE_MODEL_CACHING=true

# ---------------------------------------------------------------
# GPU
# ---------------------------------------------------------------
GPU_MEMORY_FRACTION=0.9
ENABLE_MULTI_GPU=true
GPU_MEMORY_CLEANUP=true
# PYTORCH_CUDA_ALLOC_CONF=max_split_size_mb:512

# ---------------------------------------------------------------
# Bulk Processing
# ---------------------------------------------------------------
MAX_CONCURRENT_FILES=3
BATCH_SUMMARIZATION=true
PIPELINE_OVERLAP=true

# ---------------------------------------------------------------
# Debugging
# ---------------------------------------------------------------
DEBUG=false
CLEANUP_TEMP_FILES=true
